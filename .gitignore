# =========================
# DB / migrations
# =========================

# Ignorar dumps, temporales y archivos locales de base de datos
db/**/*.tmp
db/**/*.log
db/**/*.bak
db/**/*.dump
db/**/*.sql.tmp

# NO ignorar migraciones versionadas
!db/financial/
!db/financial/migrations/
!db/financial/migrations/*.sql