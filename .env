# Local/dev environment variables
# ------------------------------------------------------------
# If you're using docker-compose, these are already injected by docker-compose.yml.
# This file is mainly for running locally via: npm run dev

# Social DB (chat)
DATABASE_URL=postgres://postgres:password@localhost:5433/social

# Identity DB (users/sessions)
IDENTITY_DATABASE_URL=postgres://postgres:password@localhost:5433/identity

# Financial DB (ledger core)
FINANCIAL_DATABASE_URL=postgres://postgres:password@localhost:5433/financial_db

# API port when running locally
PORT=3000

# Optional legacy vars (not used by the current code paths)
# FIN_DB_HOST=127.0.0.1
# FIN_DB_PORT=5433
# FIN_DB_USER=postgres
# FIN_DB_PASSWORD=UBUNTU-777
# FIN_DB_NAME=financial_db
