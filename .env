# =========================
# LOCAL / DEV ENVIRONMENT
# =========================

# Postgres credentials (from docker-compose)
DB_USER=app
DB_PASSWORD=app
DB_HOST=localhost
DB_PORT=5432

# -------------------------
# CORE DATABASES
# -------------------------

DATABASE_URL=postgres://app:app@localhost:5432/social
IDENTITY_DATABASE_URL=postgres://app:app@localhost:5432/identity
FINANCIAL_DATABASE_URL=postgres://app:app@localhost:5432/financial_db

# -------------------------
# REQUIRED BY GATEWAY
# -------------------------

CASE_DATABASE_URL=postgres://app:app@localhost:5432/case_db
RISK_DATABASE_URL=postgres://app:app@localhost:5432/risk_db
CARDS_DATABASE_URL=postgres://app:app@localhost:5432/cards_db

# -------------------------
# APP
# -------------------------

PORT=3000
NODE_ENV=development