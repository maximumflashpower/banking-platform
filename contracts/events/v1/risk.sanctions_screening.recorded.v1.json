{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "risk.sanctions_screening.recorded.v1",
  "type": "object",
  "required": [
    "screening_id",
    "subject_type",
    "subject_id",
    "screening_scope",
    "screening_status",
    "reason_code",
    "confidence_score",
    "created_at"
  ],
  "properties": {
    "screening_id": {
      "type": "string",
      "format": "uuid"
    },
    "subject_type": {
      "type": "string",
      "enum": ["kyc_individual", "kyb_business", "beneficial_owner"]
    },
    "subject_id": {
      "type": "string",
      "format": "uuid"
    },
    "screening_scope": {
      "type": "string",
      "enum": ["kyc", "kyb", "beneficial_owner"]
    },
    "screening_status": {
      "type": "string",
      "enum": ["clear", "potential_match", "confirmed_match"]
    },
    "reason_code": {
      "type": "string"
    },
    "confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "case_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}